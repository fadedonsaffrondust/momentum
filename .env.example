########################################
# Shared
########################################
NODE_ENV=development

########################################
# Database (Postgres via docker-compose)
########################################
POSTGRES_USER=momentum
POSTGRES_PASSWORD=momentum
POSTGRES_DB=momentum
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://momentum:momentum@localhost:5432/momentum

########################################
# API (apps/api)
########################################
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

########################################
# OpenAI (optional — required for brand import)
########################################
OPENAI_API_KEY=

########################################
# Web (apps/web)
########################################
VITE_API_URL=http://localhost:3001
