{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [
    "tsconfig.base.json",
    "pnpm-lock.yaml",
    ".env.example",
    "eslint.config.mjs"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "vite.config.ts",
        "tailwind.config.ts",
        "postcss.config.cjs",
        "index.html",
        "public/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "tsconfig*.json", "../../eslint.config.mjs"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**/*.{ts,tsx}", "tsconfig*.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": [
        "src/**",
        "test/**",
        "vitest.config.ts",
        "tsconfig*.json",
        "../../vitest.shared.ts"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
